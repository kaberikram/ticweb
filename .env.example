# Stripe API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Webhook (for order tracking)
STRIPE_WEBHOOK_SECRET=whsec_...
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/...

# Shipping Configuration (7 regions)
# Option 1: Comma-separated shipping rate IDs for all 7 regions (recommended)
# Order: Malaysia, Singapore, Southeast Asia, East Asia, Australia/NZ, Europe/UK, USA/Canada
SHIPPING_RATE_IDS=shr_malaysia,shr_singapore,shr_seasia,shr_eastasia,shr_au_nz,shr_europe,shr_us_ca

# Option 2: Separate rate IDs (legacy, for backward compatibility)
SHIPPING_RATE_MALAYSIA=shr_...
SHIPPING_RATE_ROW=shr_...

# Allowed shipping countries (comma-separated list, 55 countries)
SHIPPING_ALLOWED_COUNTRIES=MY,SG,TH,ID,PH,VN,KH,LA,MM,BN,TL,CN,JP,KR,TW,HK,MO,MN,AU,NZ,GB,IE,FR,DE,ES,IT,NL,BE,LU,DK,SE,FI,NO,IS,CH,AT,PT,GR,PL,CZ,HU,SK,SI,HR,RO,BG,EE,LV,LT,MT,CY,US,CA